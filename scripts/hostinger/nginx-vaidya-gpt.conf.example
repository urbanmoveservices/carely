# Example nginx reverse proxy for Vaidya GPT on Hostinger VPS.
# Place in /etc/nginx/sites-available/vaidya-gpt and symlink to sites-enabled.
# Replace YOUR_DOMAIN with your real domain.

server {
    listen 80;
    listen [::]:80;
    server_name YOUR_DOMAIN www.YOUR_DOMAIN;

    client_max_body_size 30M;

    location / {
        proxy_pass http://127.0.0.1:7111;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 300s;
    }
}

# After certbot: certbot --nginx -d YOUR_DOMAIN -d www.YOUR_DOMAIN

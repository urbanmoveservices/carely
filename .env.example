DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/carely_med_gen_ai"
JWT_SECRET="change-this-secret"

# Public app URL used for metadata, share links, emails, webhooks, sitemap
NEXT_PUBLIC_APP_URL=
APP_URL=
PUBLIC_APP_URL=

# Local development example:
# NEXT_PUBLIC_APP_URL=http://localhost:7111
# APP_URL=http://localhost:7111

# Production example:
# NEXT_PUBLIC_APP_URL=https://your-domain.com
# APP_URL=https://your-domain.com

NEXT_PUBLIC_APP_NAME="Vaidya GPT"
MAX_UPLOAD_MB=10
# IFCT 2017 (NIN/ICMR) — set true only with written permission for commercial product use
IFCT_DATA_PUBLIC_USE=false

# Optional comma-separated CORS origins (defaults to APP_URL in production)
# ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_OCR_MODEL=gpt-4o-mini

# AI token optimization
AI_COMPACT_CONTEXT_ONLY=true
AI_RAW_TEXT_MAX_CHARS=12000
AI_SNIPPET_MAX_CHARS=3000
AI_DEBUG_CONTEXT=false

OPENAI_MODEL_SUMMARY=gpt-4o-mini
OPENAI_MODEL_CHAT=gpt-4o-mini
OPENAI_MODEL_TRANSLATION=gpt-4o-mini
OPENAI_MODEL_COMPRESSION=gpt-4o-mini
OPENAI_MODEL_OCR=gpt-4o-mini

AI_MAX_OUTPUT_TOKENS_SUMMARY=1600
AI_MAX_OUTPUT_TOKENS_CHAT=700
AI_MAX_OUTPUT_TOKENS_TRANSLATION=1000
AI_MAX_OUTPUT_TOKENS_DOCTOR_QUESTIONS=900
AI_MAX_OUTPUT_TOKENS_DIET=900

WEATHER_ENABLED=false
WEATHER_PROVIDER=
WEATHER_API_KEY=
OPENAI_IMAGE_OCR_PROVIDER=openai
ENABLE_TESSERACT_OCR=false
# TESSERACT_LANG_PATH=
OPENAI_TRANSLATION_MODEL=gpt-4o-mini
MAX_MULTI_IMAGE_TOTAL_MB=30
MOCK_AI_MODE=false
LOCAL_UPLOAD_DIR="storage/uploads"
FILE_ENCRYPTION_KEY=

# Email (SMTP — dev logs to console if unset)
EMAIL_PROVIDER=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Vaidya GPT <support@vaidya-gpt.com>"
SUPPORT_EMAIL=support@vaidya-gpt.com

# Email automation & marketing (marketing off by default)
EMAIL_AUTOMATION_ENABLED=true
EMAIL_MARKETING_ENABLED=false
EMAIL_BATCH_SIZE=100
EMAIL_DAILY_MARKETING_LIMIT=5000

# Email OTP (verification + password reset)
OTP_EXPIRES_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5
DEV_PRINT_OTP=false

# Legacy alias (optional)
APP_SUPPORT_EMAIL=support@vaidya-gpt.com

# Web push (optional)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@urbanmoveservices.com

# Background worker (optional cron secret)
JOB_WORKER_SECRET=
# Admin panel login (source of truth when set — change here, then restart app)
ADMIN_NAME="Vaidya Admin"
ADMIN_EMAIL="admin@carelymed.ai"
ADMIN_PASSWORD="Admin@12345"
# Optional: npm run admin:create syncs DB user from these env vars

# Razorpay (paid plan upgrades)
# Get keys from https://dashboard.razorpay.com/app/keys
# IMPORTANT: RAZORPAY_KEY_ID and NEXT_PUBLIC_RAZORPAY_KEY_ID must be identical (same test OR same live key).
# After changing keys: npm run build && pm2 restart (NEXT_PUBLIC is baked in at build time).
RAZORPAY_ENABLED=true
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_CURRENCY=INR

# E2E only: POST /api/test/force-plan for @vaidya.test users (never enable in production)
E2E_ALLOW_TEST_HELPERS=false
# E2E: GET /api/test/latest-otp for @vaidya.test (requires E2E_ALLOW_TEST_HELPERS=true)

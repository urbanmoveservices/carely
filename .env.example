DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/carely_med_gen_ai"
JWT_SECRET="change-this-secret"

# Public app URL used for metadata, share links, emails, webhooks, sitemap
NEXT_PUBLIC_APP_URL=
APP_URL=
PUBLIC_APP_URL=

# Local development example:
# NEXT_PUBLIC_APP_URL=http://localhost:7111
# APP_URL=http://localhost:7111

# Production example:
# NEXT_PUBLIC_APP_URL=https://your-domain.com
# APP_URL=https://your-domain.com

NEXT_PUBLIC_APP_NAME="Vaidya GPT"
MAX_UPLOAD_MB=10
# IFCT 2017 (NIN/ICMR) — set true only with written permission for commercial product use
IFCT_DATA_PUBLIC_USE=false

# Optional comma-separated CORS origins (defaults to APP_URL in production)
# ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_OCR_MODEL=gpt-4o-mini
OPENAI_IMAGE_OCR_PROVIDER=openai
ENABLE_TESSERACT_OCR=false
# TESSERACT_LANG_PATH=
OPENAI_TRANSLATION_MODEL=gpt-4o-mini
MAX_MULTI_IMAGE_TOTAL_MB=30
MOCK_AI_MODE=false
LOCAL_UPLOAD_DIR="storage/uploads"
FILE_ENCRYPTION_KEY=

# Email (SMTP — dev logs to console if unset)
EMAIL_PROVIDER=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
APP_SUPPORT_EMAIL=support@urbanmoveservices.com

# Web push (optional)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@urbanmoveservices.com

# Background worker (optional cron secret)
JOB_WORKER_SECRET=
ADMIN_NAME="Vaidya Admin"
ADMIN_EMAIL="admin@carelymed.ai"
ADMIN_PASSWORD="Admin@12345"

# Razorpay (paid plan upgrades — test keys run in test mode; swap for live keys in production)
# Get keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_ENABLED=true
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_CURRENCY=INR

# E2E only: POST /api/test/force-plan for @vaidya.test users (never enable in production)
E2E_ALLOW_TEST_HELPERS=false

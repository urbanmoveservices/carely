# Copy to .env.deploy (never commit .env.deploy)
# Used by: npm run deploy:hostinger

# --- Git ---
GIT_REMOTE=origin
GIT_BRANCH=main
# Required when you have uncommitted changes:
# DEPLOY_COMMIT_MESSAGE=Deploy latest changes

# --- Hostinger SSH (VPS) ---
HOSTINGER_SSH_HOST=your-server.hostinger.com
HOSTINGER_SSH_USER=root
HOSTINGER_SSH_PORT=22
# Optional path to private key (OpenSSH format)
# HOSTINGER_SSH_KEY=C:\Users\you\.ssh\id_ed25519

# Absolute path to the app on the server (repo clone location)
HOSTINGER_DEPLOY_PATH=/var/www/vaidya-gpt

# PM2 app name (must match ecosystem.config.cjs)
PM2_APP_NAME=vaidya-gpt

# --- Options ---
# DEPLOY_SKIP_CHECKS=false
# DEPLOY_SKIP_GIT=false
# DEPLOY_SKIP_REMOTE=false
# DEPLOY_DRY_RUN=false
